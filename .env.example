# IslamicLMS v2.0 Environment Variables

# Django Settings
SECRET_KEY=django-insecure-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30

# Google OAuth (for teacher Google login + Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback


# Database
# If DATABASE_URL is not set, SQLite will be used locally
# DATABASE_URL=postgres://user:password@localhost:5432/islamiclms

# Channels / Redis
# If REDIS_URL is not set, InMemoryChannelLayer will be used for dev
# REDIS_URL=redis://localhost:6379/1

# Celery
CELERY_ENABLED=False

# AI Credentials
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Sentry
SENTRY_DSN=

# New Relic
NEW_RELIC_LICENSE_KEY=
